{
  "name": "cr-wildlife-appflow",
  "version": "1.0.0",
  "description": "Aplicación móvil de Costa Rica WildLife Tours para Appflow",
  "main": "www/index.html",
  "scripts": {
    "build": "cordova build android",
    "build:prod": "cordova build android --release",
    "build:ios": "cordova build ios",
    "build:ios:prod": "cordova build ios --release",
    "emulate": "cordova emulate android",
    "prepare": "cordova prepare",
    "clean": "cordova clean",
    "resources": "cordova-res",
    "sync": "cordova prepare && cordova build",
    "version": "echo $npm_package_version"
  },
  "keywords": [
    "cordova",
    "appflow",
    "ionic",
    "wildlife",
    "costarica"
  ],
  "author": "CR Wildlife Tours",
  "license": "MIT",
  "dependencies": {
    "cordova": "^12.0.0",
    "cordova-android": "^12.0.0",
    "cordova-ios": "^7.0.0",
    "cordova-plugin-camera": "^7.0.0",
    "cordova-plugin-device": "^2.1.0",
    "cordova-plugin-dialogs": "^2.0.2",
    "cordova-plugin-file": "^8.0.1",
    "cordova-plugin-geolocation": "^5.0.0",
    "cordova-plugin-inappbrowser": "^6.0.0",
    "cordova-plugin-network-information": "^3.0.0",
    "cordova-plugin-splashscreen": "^6.0.2",
    "cordova-plugin-statusbar": "^4.0.0",
    "cordova-plugin-vibration": "^3.1.1",
    "cordova-plugin-whitelist": "^1.3.5"
  },
  "devDependencies": {
    "cordova-res": "^0.15.4",
    "cordova-paramedic": "^1.6.0"
  },
  "cordova": {
    "platforms": [
      "android",
      "ios"
    ],
    "plugins": {
      "cordova-plugin-whitelist": {},
      "cordova-plugin-splashscreen": {},
      "cordova-plugin-statusbar": {},
      "cordova-plugin-network-information": {},
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-geolocation": {
        "GEOLOCATION_USAGE_DESCRIPTION": "Para mostrarte los mejores lugares de herping cerca de ti"
      },
      "cordova-plugin-camera": {
        "CAMERA_USAGE_DESCRIPTION": "Para capturar fotos de tus expediciones"
      },
      "cordova-plugin-file": {},
      "cordova-plugin-dialogs": {},
      "cordova-plugin-vibration": {},
      "cordova-plugin-device": {}
    }
  }
}