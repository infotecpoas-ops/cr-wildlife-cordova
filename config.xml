<?xml version='1.0' encoding='utf-8'?>
<widget id="com.crwildlife.tours" 
        version="1.0.0" 
        xmlns="http://www.w3.org/ns/widgets" 
        xmlns:cdv="http://cordova.apache.org/ns/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">
    
    <name>Costa Rica WildLife Tours</name>
    <description>Expediciones de vida silvestre, herping y conservación en Costa Rica</description>
    <author email="crlifewildtours@gmail.com" href="https://crwildlife.com">
        CR Wildlife Tours
    </author>
    
    <content src="index.html" />
    
    <!-- Acceso a URLs -->
    <access origin="*" />
    <allow-navigation href="*" />
    <allow-intent href="*" />
    
    <!-- Permisos para WhatsApp y Redes Sociales -->
    <allow-intent href="https://wa.me/*" />
    <allow-intent href="whatsapp://*" />
    <allow-intent href="https://api.whatsapp.com/*" />
    <allow-intent href="https://facebook.com/*" />
    <allow-intent href="https://instagram.com/*" />
    <allow-intent href="https://youtube.com/*" />
    
    <!-- Permisos para Correo y Teléfono -->
    <allow-intent href="mailto:*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    
    <!-- Preferencias Generales -->
    <preference name="Fullscreen" value="false" />
    <preference name="Orientation" value="portrait" />
    <preference name="StatusBarOverlaysWebView" value="true" />
    <preference name="StatusBarBackgroundColor" value="#0a0a0a" />
    <preference name="StatusBarStyle" value="lightcontent" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="BackupWebStorage" value="local" />
    <preference name="SplashScreenDelay" value="3000" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />
    
    <!-- Preferencias específicas para Android -->
    <platform name="android">
        <preference name="AndroidMinSdkVersion" value="22" />
        <preference name="AndroidTargetSdkVersion" value="33" />
        <preference name="AndroidCompileSdkVersion" value="33" />
        <preference name="AndroidXEnabled" value="true" />
        
        <!-- Iconos para Android -->
        <icon density="ldpi" src="resources/android/icon/drawable-ldpi-icon.png" />
        <icon density="mdpi" src="resources/android/icon/drawable-mdpi-icon.png" />
        <icon density="hdpi" src="resources/android/icon/drawable-hdpi-icon.png" />
        <icon density="xhdpi" src="resources/android/icon/drawable-xhdpi-icon.png" />
        <icon density="xxhdpi" src="resources/android/icon/drawable-xxhdpi-icon.png" />
        <icon density="xxxhdpi" src="resources/android/icon/drawable-xxxhdpi-icon.png" />
        
        <!-- Splash screens para Android -->
        <splash density="land-ldpi" src="resources/android/splash/drawable-land-ldpi-screen.png" />
        <splash density="land-mdpi" src="resources/android/splash/drawable-land-mdpi-screen.png" />
        <splash density="land-hdpi" src="resources/android/splash/drawable-land-hdpi-screen.png" />
        <splash density="land-xhdpi" src="resources/android/splash/drawable-land-xhdpi-screen.png" />
        <splash density="land-xxhdpi" src="resources/android/splash/drawable-land-xxhdpi-screen.png" />
        <splash density="land-xxxhdpi" src="resources/android/splash/drawable-land-xxxhdpi-screen.png" />
        <splash density="port-ldpi" src="resources/android/splash/drawable-port-ldpi-screen.png" />
        <splash density="port-mdpi" src="resources/android/splash/drawable-port-mdpi-screen.png" />
        <splash density="port-hdpi" src="resources/android/splash/drawable-port-hdpi-screen.png" />
        <splash density="port-xhdpi" src="resources/android/splash/drawable-port-xhdpi-screen.png" />
        <splash density="port-xxhdpi" src="resources/android/splash/drawable-port-xxhdpi-screen.png" />
        <splash density="port-xxxhdpi" src="resources/android/splash/drawable-port-xxxhdpi-screen.png" />
    </platform>
    
    <!-- Preferencias específicas para iOS -->
    <platform name="ios">
        <preference name="TargetDevice" value="handset" />
        <preference name="deployment-target" value="11.0" />
        
        <!-- Iconos para iOS -->
        <icon height="180" src="resources/ios/icon/icon-60@3x.png" width="180" />
        <icon height="60" src="resources/ios/icon/icon-60.png" width="60" />
        <icon height="120" src="resources/ios/icon/icon-60@2x.png" width="120" />
        <icon height="76" src="resources/ios/icon/icon-76.png" width="76" />
        <icon height="152" src="resources/ios/icon/icon-76@2x.png" width="152" />
        
        <!-- Splash screens para iOS -->
        <splash height="1136" src="resources/ios/splash/Default-568h@2x~iphone.png" width="640" />
        <splash height="1334" src="resources/ios/splash/Default-667h.png" width="750" />
        <splash height="2208" src="resources/ios/splash/Default-736h.png" width="1242" />
        <splash height="2732" src="resources/ios/splash/Default@2x~universal~anyany.png" width="2732" />
    </platform>
    
    <!-- Hooks para automatización -->
    <hook type="after_prepare" src="hooks/after_prepare.js" />
    
    <!-- Plugins requeridos -->
    <plugin name="cordova-plugin-whitelist" spec="*" />
    <plugin name="cordova-plugin-splashscreen" spec="*" />
    <plugin name="cordova-plugin-statusbar" spec="*" />
    <plugin name="cordova-plugin-network-information" spec="*" />
    <plugin name="cordova-plugin-inappbrowser" spec="*" />
    <plugin name="cordova-plugin-geolocation" spec="*" />
    <plugin name="cordova-plugin-camera" spec="*" />
    <plugin name="cordova-plugin-file" spec="*" />
    <plugin name="cordova-plugin-dialogs" spec="*" />
    <plugin name="cordova-plugin-vibration" spec="*" />
    <plugin name="cordova-plugin-device" spec="*" />
</widget>